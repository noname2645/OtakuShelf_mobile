{
  "expo": {
    "name": "OtakuShelf",
    "slug": "otakushelf-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "otakushelf",
    "icon": "./assets/otakushelf_app_icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/otakushelf_app_icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0f1e"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/otakushelf_app_icon.png",
        "backgroundColor": "#0a0f1e"
      },
      "package": "com.otakushelf.mobile",
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "androidNavigationBar": {
      "backgroundColor": "#0a0f1e",
      "barStyle": "light-content"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you set profile pictures."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "b9230cc0-05d5-4d96-b755-5f8597059ce4"
      }
    }
  }
}
